# Backend REST API base URL
VITE_API_URL=http://localhost:3000

# PostHog (Feature C — A/B toggle). Leave empty to disable PostHog locally;
# the app then always shows the default UI (variant A).
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://eu.i.posthog.com

# Target host for the Playwright E2E suite (npm run test:e2e). Not used by the
# app itself. CI injects this automatically; set it here for local runs, e.g.
# E2E_BASE_URL=http://ip/staging/
E2E_BASE_URL=
